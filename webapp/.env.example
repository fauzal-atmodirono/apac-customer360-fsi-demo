# Copy to .env.local for local dev; set the same keys as env vars on Cloud Run.

# ── Collections bot integration (the Outreach page proxies to it server-side) ──
# The browser never holds BOT_API_KEY — app/api/outreach/[...path]/route.ts injects
# it as X-Bot-Key when forwarding to the bot. BOT_API_KEY MUST match the bot's .env.
BOT_URL=http://localhost:8100          # deployed: https://c360-collections-bot-xxxx.a.run.app
BOT_API_KEY=                           # same 64-char secret as collections-bot/.env

# ── ADK "Ask the data" agent (agent/, optional) ──
AGENT_URL=http://localhost:8000        # deployed: the agent's Cloud Run URL

# ── BigQuery / data (defaults baked into lib/bigquery.ts; override per project) ──
GCP_PROJECT=nbs-playground-data-analytics
BQ_LOCATION=asia-southeast2
GOLD_DATASET=demo_gold_analytics
SILVER_DATASET=demo_silver_banking
MASKED_SA=                             # masked-reader SA to impersonate for the governance view

# ── Auth (Auth.js v5 + Google) ──
# The service runs private on Cloud Run, so auth is bypassed for the demo:
DISABLE_AUTH=true
# When DISABLE_AUTH is not true, configure Google sign-in + who may log in:
# AUTH_SECRET=            # openssl rand -base64 32
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# ALLOWED_DOMAIN=devoteam.com          # restrict to a Google Workspace domain
# ALLOWED_EMAILS=a@x.com,b@x.com       # or an explicit allow-list
# ALLOW_ANY_GOOGLE=false               # true = any Google account (demo only)
