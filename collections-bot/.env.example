# Twilio core
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Senders (one purchased number)
TWILIO_SMS_FROM=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Email via SMTP (send-only; e.g. Gmail SMTP + app password, or any SMTP host)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password
SMTP_STARTTLS=true
EMAIL_FROM=collections@example.com
EMAIL_FROM_NAME=Bank Muamalat Collections
# Gemini via Vertex AI (ADC — run: gcloud auth application-default login)
# Leave GOOGLE_API_KEY empty to use ADC/Vertex; set it only for the Gemini Developer API.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_LOCATION=global
# Optional: run Vertex/Gemini in a different project than GCP_PROJECT (e.g. the deploy
# project). Leave empty to use GCP_PROJECT.
VERTEX_PROJECT=
# BigQuery lookup
GCP_PROJECT=nbs-playground-data-analytics
# Optional: run BQ jobs in a DIFFERENT project than the tables (cross-project deploy).
# Leave empty to run jobs in GCP_PROJECT. Tables are always qualified by GCP_PROJECT.
BQ_JOB_PROJECT=
BQ_LOCATION=asia-southeast2
GOLD_DATASET=demo_gold_analytics
# Conversation store: 'sqlite' (default, local/single-instance) or 'firestore'
# (serverless, multi-instance-safe; lets the Cloud Run deploy scale past 1 instance).
STORE_BACKEND=sqlite
# Contacts source: 'json' (demo-contacts.json, baked into the image) or 'firestore'
# (editable in the Firebase console, no redeploy). Seed once: python seed_contacts.py
CONTACTS_BACKEND=json
# For STORE_BACKEND=firestore — the DB may live in a DIFFERENT project than the bot.
# The runtime SA needs roles/datastore.user granted ON that project.
FIRESTORE_PROJECT=lv-playground-genai
FIRESTORE_DATABASE=customer360-db
# Service
BOT_PORT=8100
CONVERSATION_DB_PATH=./conversations.sqlite
PUBLIC_BASE_URL=
VERIFY_TWILIO_SIGNATURE=true
BOT_API_KEY=                                 # shared secret; webapp proxy sends it as X-Bot-Key
# Channels to fake (comma-sep): compose the real message + show it as 'simulated' but skip the
# actual send. Use for SMS that can't route to the demo region. WhatsApp/email stay real.
SIMULATE_CHANNELS=                           # e.g. sms
# Demo lever: override "today" (ISO date) for promise-to-pay suppression, so a PTP can be
# expired without waiting days. Leave empty for the real Asia/Kuala_Lumpur date.
BOT_FAKE_TODAY=
